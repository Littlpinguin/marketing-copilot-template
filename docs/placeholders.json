{
  "$schema": "./placeholders.schema.json",
  "version": "0.2.0",
  "description": "Canonical list of Mustache-style placeholders used in templates. The wizard replaces them; /validate-setup blocks if any remain.",
  "groups": {
    "identity": [
      { "name": "COMPANY_NAME",          "required": true,  "example": "Acme Inc." },
      { "name": "COMPANY_SHORT_NAME",    "required": true,  "example": "Acme" },
      { "name": "COMPANY_WEBSITE",       "required": true,  "example": "https://acme.com" },
      { "name": "COMPANY_TAGLINE",       "required": false, "example": "Ship faster, ship better" },
      { "name": "COMPANY_POSITIONING",   "required": true,  "example": "The first developer-first CI platform that scales from solo to enterprise." },
      { "name": "COMPANY_MISSION",       "required": false, "example": "Empower every developer to ship with confidence" },
      { "name": "COMPANY_VISION",        "required": false, "example": "A world where shipping code is boring and boring means reliable" },
      { "name": "COMPANY_SECTOR",        "required": false, "example": "DevOps SaaS" },
      { "name": "COMPANY_AUDIENCE_SHORT","required": true,  "example": "developers and devops teams" },
      { "name": "COMPANY_HQ",            "required": false, "example": "Paris, France" },
      { "name": "COMPANY_FOUNDERS",      "required": false, "example": "Alice Dupont, Bob Martin" },
      { "name": "COMPANY_MAIN_CONTACT",  "required": true,  "example": "Claire Durand, Head of Marketing" },
      { "name": "SALES_CONTACT",         "required": false, "example": "Paul Bernard, Sales" }
    ],
    "visual_identity": [
      { "name": "BRAND_FONT_PRIMARY",       "required": true,  "example": "Inter" },
      { "name": "BRAND_FONT_SECONDARY",     "required": false, "example": "JetBrains Mono" },
      { "name": "BRAND_COLOR_PRIMARY",      "required": true,  "example": "#1E40AF" },
      { "name": "BRAND_COLOR_ACCENT",       "required": true,  "example": "#F59E0B" },
      { "name": "BRAND_COLOR_DARK",         "required": true,  "example": "#0F172A" },
      { "name": "BRAND_COLOR_LIGHT",        "required": true,  "example": "#F8FAFC" },
      { "name": "BRAND_GRADIENT",           "required": false, "example": "linear-gradient(90deg, #1E40AF 0%, #F59E0B 100%)" },
      { "name": "BRAND_BORDER_RADIUS",      "required": false, "example": "12-24px" },
      { "name": "BRAND_ILLUSTRATION_STYLE", "required": true,  "example": "Minimalist line art, isometric, no stock photos" },
      { "name": "BRAND_BANNED_VISUALS",     "required": true,  "example": "stock office photos, handshakes, generic laptops, post-its" }
    ],
    "voice": [
      { "name": "BRAND_VOICE_POSITION",       "required": true,  "example": "Expert accessible: rigorous content, warm delivery" },
      { "name": "BRAND_VOCABULARY_PREFERRED", "required": true,  "example": "platform, team, ship, deploy, developer" },
      { "name": "BRAND_VOCABULARY_BANNED",    "required": true,  "example": "solution, innovation, game-changer, disrupt, synergy" },
      { "name": "BRAND_TAGLINES",             "required": false, "example": "Ship faster, ship better. | Boring is the new exciting." },
      { "name": "BRAND_TOP_NUMBERS",          "required": false, "example": "99.9% uptime | 10k+ developers | 50% faster CI" },
      { "name": "BRAND_DEFAULT_LANGUAGE",     "required": true,  "example": "en" },
      { "name": "BRAND_BILINGUAL",            "required": true,  "example": "false" },
      { "name": "BILINGUAL_RULES",            "required": false, "example": "EN first, FR cultural adaptation" },
      { "name": "TYPOGRAPHY_RULES",           "required": false, "example": "No em dashes, single space after period" }
    ],
    "personas": [
      { "name": "PERSONA_1_NAME",          "required": true },
      { "name": "PERSONA_1_DETAILS",       "required": true },
      { "name": "PERSONA_2_NAME",          "required": false },
      { "name": "PERSONA_2_DETAILS",       "required": false },
      { "name": "PERSONA_3_NAME",          "required": false },
      { "name": "PERSONA_3_DETAILS",       "required": false },
      { "name": "PERSONA_4_NAME",          "required": false },
      { "name": "PERSONA_4_DETAILS",       "required": false },
      { "name": "PERSONA_CHANNEL_MATRIX",  "required": false }
    ],
    "pillars_cadence": [
      { "name": "PILLAR_1", "required": true,  "example": "Data & Expertise (40%) — stats, benchmarks — LinkedIn, Blog" },
      { "name": "PILLAR_2", "required": false },
      { "name": "PILLAR_3", "required": false },
      { "name": "PILLAR_4", "required": false },
      { "name": "PILLAR_5", "required": false },
      { "name": "CONTENT_CADENCE_LINKEDIN",   "required": false, "example": "4-5 posts / week" },
      { "name": "CONTENT_CADENCE_NEWSLETTER", "required": false, "example": "Monthly" },
      { "name": "CONTENT_CADENCE_BLOG",       "required": false, "example": "2 articles / month" },
      { "name": "CONTENT_CADENCE_DISCORD",    "required": false, "example": "Weekly" },
      { "name": "CONTENT_CADENCE_WHATSAPP",   "required": false, "example": "Max 2 / week" },
      { "name": "CONTENT_KPIS",               "required": false }
    ],
    "skill_personalization": [
      { "name": "BRAND_SPECIFIC_CHECK_RULES", "used_in": "brand-check" },
      { "name": "SOCIAL_VOICE_DOS",           "used_in": "social-content" },
      { "name": "SOCIAL_VOICE_DONTS",         "used_in": "social-content" },
      { "name": "SOCIAL_HOOK_EXAMPLES",       "used_in": "social-content" },
      { "name": "SOCIAL_SPECIFIC_RULES",      "used_in": "social-content" },
      { "name": "SOCIAL_EMOJI_RULE",          "used_in": "social-content", "example": "Sparingly, max 1 per post" },
      { "name": "SOCIAL_DASH_RULE",           "used_in": "social-content", "example": "No em dashes" },
      { "name": "COPYWRITING_SPECIFIC_RULES", "used_in": "copywriting" },
      { "name": "COPY_EDITING_SPECIFIC_RULES","used_in": "copy-editing" },
      { "name": "STRATEGY_SPECIFIC_RULES",    "used_in": "content-strategy" },
      { "name": "SEO_CLUSTERS",               "used_in": "seo" },
      { "name": "SEO_SPECIFIC_RULES",         "used_in": "seo" },
      { "name": "EMAIL_SPECIFIC_RULES",       "used_in": "email" },
      { "name": "EMAIL_SIGNATURE_LINE",       "used_in": "email", "example": "Talk soon," },
      { "name": "NEWSLETTER_VOICE",           "used_in": "email" },
      { "name": "PROMO_VOICE",                "used_in": "email" },
      { "name": "SALES_VOICE",                "used_in": "email" },
      { "name": "EVENT_SPECIFIC_RULES",       "used_in": "event-marketing" },
      { "name": "EVENT_TEAM",                 "used_in": "event-marketing" },
      { "name": "IMAGE_GEN_SPECIFIC_RULES",   "used_in": "image-generation" },
      { "name": "IMAGE_GEN_EXAMPLES",         "used_in": "image-generation" },
      { "name": "SLIDES_SPECIFIC_RULES",      "used_in": "slides" },
      { "name": "BLOG_CMS",                   "used_in": "seo, 09-seo", "example": "WordPress / Ghost / Hashnode" }
    ],
    "tools": [
      { "name": "EDITORIAL_CALENDAR_TOOL" },
      { "name": "EDITORIAL_CALENDAR_ENABLED" },
      { "name": "EDITORIAL_CALENDAR_STATUS_FILTER" },
      { "name": "EMAIL_MARKETING_TOOL" },
      { "name": "EMAIL_MARKETING_ENABLED" },
      { "name": "EMAIL_MARKETING_ENV_KEY" },
      { "name": "EMAIL_MARKETING_LIST_ID" },
      { "name": "KNOWLEDGE_BASE_TOOL" },
      { "name": "KNOWLEDGE_BASE_ENABLED" },
      { "name": "KNOWLEDGE_BASE_URL" },
      { "name": "KNOWLEDGE_BASE_ENV_KEY" },
      { "name": "EVENTS_PLATFORM_TOOL" },
      { "name": "EVENTS_PLATFORM_ENABLED" },
      { "name": "EVENTS_PLATFORM_ENV_KEY" },
      { "name": "CRM_TOOL" },
      { "name": "CRM_ENABLED" },
      { "name": "IMAGE_GENERATION_ENABLED" }
    ],
    "decks": [
      { "name": "DECK_TITLE",   "marker": true, "used_in": "06-graphic-design/presentations/templates/base.html", "description": "Title for an individual deck — replaced when copying base.html into decks/" }
    ],
    "signatures": [
      { "name": "NAME",         "used_in": "06-graphic-design/mail-signatures/template.html" },
      { "name": "ROLE",         "used_in": "06-graphic-design/mail-signatures/template.html" },
      { "name": "EMAIL",        "used_in": "06-graphic-design/mail-signatures/template.html" },
      { "name": "PHONE",        "used_in": "06-graphic-design/mail-signatures/template.html", "required": false },
      { "name": "LINKEDIN_URL", "used_in": "06-graphic-design/mail-signatures/template.html", "required": false }
    ],
    "project_meta": [
      { "name": "PROJECT_SLUG", "required": true, "example": "acme-marketing-copilot" },
      { "name": "PROJECT_ROOT", "required": true, "example": "/Users/alice/code/acme-copilot" },
      { "name": "SETUP_DATE",   "required": true, "example": "2026-04-15" },
      { "name": "TODO",         "marker": true,   "description": "Temporary marker for gaps to fill later" },
      { "name": "MONTH_YEAR",   "used_in": "04-email/newsletter/drafts/", "example": "MARCH_2026" }
    ]
  }
}
