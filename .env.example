# ============================================================
# Marketing Cockpit Template - Environment variables
# ============================================================
#
# Copy this file to .env and fill in the values.
# The bootstrap interview (run Claude Code at the project root)
# will prompt you for each value and can write them here automatically.
#
# NEVER commit .env to git. It is listed in .gitignore.
#
# Variables marked REQUIRED must be set for the system to work.
# Variables marked OPTIONAL enable additional integrations.

# ------------------------------------------------------------
# Google AI — enrichment AND image generation (REQUIRED)
# ------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# A single key powers TWO capabilities of the cockpit:
#   1. Content enrichment (gemini-2.5-flash) — summary, entities, claims, meeting extraction
#   2. Brand-compliant image generation (gemini-3-pro-image-preview, aka "nano banana pro")
#      — visuals that respect your color palette, typography, illustration style, and avoid
#      your banned visual tropes (e.g. stock photos, generic office imagery).
#
# The image generation capability is used by the `image-generation` skill which wraps
# every prompt with your brand guidelines before calling Gemini. See
# `06-graphic-design/CLAUDE.md` and `.agents/skills/image-generation.md` for the workflow.
GOOGLE_AI_API_KEY=""
GOOGLE_AI_IMAGE_MODEL="gemini-3-pro-image-preview"

# ------------------------------------------------------------
# Editorial calendar (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# Notion API — https://developers.notion.com
NOTION_API_KEY=""
NOTION_EDITORIAL_DATABASE_ID=""

# Airtable — https://airtable.com/developers/web/api/introduction
AIRTABLE_API_KEY=""
AIRTABLE_BASE_ID=""
AIRTABLE_TABLE_NAME=""

# ------------------------------------------------------------
# Email marketing (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# MailerLite — https://developers.mailerlite.com
MAILERLITE_API_KEY=""
MAILERLITE_GROUP_ID=""

# Mailchimp
MAILCHIMP_API_KEY=""
MAILCHIMP_AUDIENCE_ID=""
MAILCHIMP_SERVER_PREFIX=""

# Resend
RESEND_API_KEY=""

# Brevo (formerly Sendinblue)
BREVO_API_KEY=""

# ------------------------------------------------------------
# Knowledge base (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# Outline — https://www.getoutline.com/developers
OUTLINE_API_KEY=""
OUTLINE_URL="https://app.getoutline.com"

# Confluence
CONFLUENCE_API_TOKEN=""
CONFLUENCE_BASE_URL=""
CONFLUENCE_USER_EMAIL=""

# GitBook
GITBOOK_API_TOKEN=""

# ------------------------------------------------------------
# Events / webinars (OPTIONAL)
# ------------------------------------------------------------
# Livestorm — note: no "Bearer" prefix for Livestorm
LIVESTORM_API_KEY=""

# Zoom
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# ------------------------------------------------------------
# CRM (OPTIONAL)
# ------------------------------------------------------------
# HubSpot
HUBSPOT_API_KEY=""

# Pipedrive
PIPEDRIVE_API_TOKEN=""
PIPEDRIVE_DOMAIN=""

# ------------------------------------------------------------
# Scraping — Apify (OPTIONAL, module `acquisition` / skill `scraping`)
# ------------------------------------------------------------
# Get a token at https://console.apify.com/settings/integrations
APIFY_TOKEN=""

# ------------------------------------------------------------
# Automations — n8n (OPTIONAL, modules `automatisations` / `acquisition`)
# ------------------------------------------------------------
# URL of your n8n instance API (e.g. https://n8n.example.com/api/v1)
# and an API key created in n8n > Settings > API.
# These .env values are read by SCRIPTS (e.g. 10-automatisations/scripts/backup-workflows.sh).
# The n8n-mcp SERVER does NOT read this file: put the real values in your local,
# untracked .mcp.json as well (copy .mcp.json.example — see 10-automatisations/mcp-setup.md).
# ${VAR} references in .mcp.json are NOT expanded from this .env (see SECURITY.md).
N8N_API_URL=""
N8N_API_KEY=""

# ------------------------------------------------------------
# Client space — FTP (OPTIONAL, module `espace-client`)
# ------------------------------------------------------------
# Credentials for the FTP/SFTP space where client deliverables are published.
FTP_HOST=""
FTP_PORT="21"
FTP_USER=""
FTP_PASSWORD=""
FTP_REMOTE_DIR=""

# ------------------------------------------------------------
# Google Ads — MCP mcp-google-ads (OPTIONAL, module `acquisition`, skill `sea-google-ads`)
# ------------------------------------------------------------
# No .env variables here: the Google Ads credentials are consumed by an MCP SERVER,
# so they live in your local, untracked .mcp.json (real values — ${VAR} references
# are NOT expanded from this .env). Full setup: 12-acquisition/google-ads/setup.md.
# The MCP server runs READ-ONLY by default (GOOGLE_ADS_READ_ONLY=true in .mcp.json).

# ------------------------------------------------------------
# Cold outreach — Lemlist (OPTIONAL, module `acquisition`)
# ------------------------------------------------------------
# No .env variable here: Lemlist connects via its official MCP server.
# Prefer OAuth (no static token at all — Claude Code handles auth). If you use an
# API key instead, put it directly in your local, untracked .mcp.json.
# Full setup: 12-acquisition/setup-lemlist.md.

# ------------------------------------------------------------
# Social publishing — Postiz (OPTIONAL, module `publication-sociale`)
# ------------------------------------------------------------
# URL of your Postiz instance API and an API key from Postiz settings.
POSTIZ_API_URL=""
POSTIZ_API_KEY=""

