# ============================================================
# Marketing Copilot Template - Environment variables
# ============================================================
#
# Copy this file to .env and fill in the values.
# The bootstrap interview (run Claude Code at the project root)
# will prompt you for each value and can write them here automatically.
#
# NEVER commit .env to git. It is listed in .gitignore.
#
# Variables marked REQUIRED must be set for the system to work.
# Variables marked OPTIONAL enable additional integrations.

# ------------------------------------------------------------
# Qdrant — semantic memory (REQUIRED if you enable Qdrant)
# ------------------------------------------------------------
# Sign up for a free cluster at https://cloud.qdrant.io
# The key must be a "Cluster API Key" (data access), not a management key.
# Wrap the key in double quotes if it contains a pipe character.
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="knowledge"

# ------------------------------------------------------------
# Google AI — embeddings, enrichment AND image generation (REQUIRED)
# ------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# A single key powers THREE capabilities of the copilot:
#   1. Semantic embeddings (gemini-embedding-001, 3072 dim) — indexing + retrieval
#   2. Content enrichment (gemini-2.5-flash) — summary, entities, claims, meeting extraction
#   3. Brand-compliant image generation (gemini-3-pro-image-preview, aka "nano banana pro")
#      — visuals that respect your color palette, typography, illustration style, and avoid
#      your banned visual tropes (e.g. stock photos, generic office imagery).
#
# The image generation capability is used by the `image-generation` skill which wraps
# every prompt with your brand guidelines before calling Gemini. See
# `06-graphic-design/CLAUDE.md` and `.agents/skills/image-generation.md` for the workflow.
GOOGLE_AI_API_KEY=""
GOOGLE_AI_IMAGE_MODEL="gemini-3-pro-image-preview"

# ------------------------------------------------------------
# Editorial calendar (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# Notion API — https://developers.notion.com
NOTION_API_KEY=""
NOTION_EDITORIAL_DATABASE_ID=""

# Airtable — https://airtable.com/developers/web/api/introduction
AIRTABLE_API_KEY=""
AIRTABLE_BASE_ID=""
AIRTABLE_TABLE_NAME=""

# ------------------------------------------------------------
# Email marketing (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# MailerLite — https://developers.mailerlite.com
MAILERLITE_API_KEY=""
MAILERLITE_GROUP_ID=""

# Mailchimp
MAILCHIMP_API_KEY=""
MAILCHIMP_AUDIENCE_ID=""
MAILCHIMP_SERVER_PREFIX=""

# Resend
RESEND_API_KEY=""

# Brevo (formerly Sendinblue)
BREVO_API_KEY=""

# ------------------------------------------------------------
# Knowledge base (OPTIONAL — choose ONE tool)
# ------------------------------------------------------------
# Outline — https://www.getoutline.com/developers
OUTLINE_API_KEY=""
OUTLINE_URL="https://app.getoutline.com"

# Confluence
CONFLUENCE_API_TOKEN=""
CONFLUENCE_BASE_URL=""
CONFLUENCE_USER_EMAIL=""

# GitBook
GITBOOK_API_TOKEN=""

# ------------------------------------------------------------
# Events / webinars (OPTIONAL)
# ------------------------------------------------------------
# Livestorm — note: no "Bearer" prefix for Livestorm
LIVESTORM_API_KEY=""

# Zoom
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# ------------------------------------------------------------
# CRM (OPTIONAL)
# ------------------------------------------------------------
# HubSpot
HUBSPOT_API_KEY=""

# Pipedrive
PIPEDRIVE_API_TOKEN=""
PIPEDRIVE_DOMAIN=""

